{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/blog/?$", "dest": "/blog.html" },
    { "src": "/blog/(.*)\\.html$", "dest": "/blog/$1.html" },
    { "src": "/blog/([^/.]+)$", "dest": "/blog/$1.html" },
    { "src": "/(.*)", "dest": "/creadil.html" }
  ]
}
